generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int        @id @default(autoincrement())
  name       String
  email      String     @unique
  phone      String?
  aadhaarRef String?
  verified   Boolean    @default(false)
  location   Location?  @relation(fields: [locationId], references: [id])
  locationId Int?
  createdAt  DateTime   @default(now())
  applications Application[]
  verifications Verification[]
  ratings       Rating[]
}

model Company {
  id        Int     @id @default(autoincrement())
  name      String
  website   String?
  createdAt DateTime @default(now())
  jobs      Job[]
}

model Job {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  salaryMin   Int?
  salaryMax   Int?
  remote      Boolean   @default(false)
  lat         Float?
  lon         Float?
  source      String?
  url         String?
  postedAt    DateTime  @default(now())
  company     Company?  @relation(fields: [companyId], references: [id])
  companyId   Int?
  createdAt   DateTime  @default(now())
  applications Application[]
}

model Application {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  job       Job      @relation(fields: [jobId], references: [id])
  jobId     Int
  status    String   @default("applied")
  score     Float?
  createdAt DateTime @default(now())
}

model Verification {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  fileRef    String
  verified   Boolean  @default(false)
  provider   String?
  createdAt  DateTime @default(now())
}

model Location {
  id        Int     @id @default(autoincrement())
  name      String?
  lat       Float
  lon       Float
  createdAt DateTime @default(now())
  users     User[]
}

model Rating {
  id        Int     @id @default(autoincrement())
  user      User    @relation(fields: [userId], references: [id])
  userId    Int
  score     Int
  review    String?
  createdAt DateTime @default(now())
}
